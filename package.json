{
  "name": "hyperliquid-reactnative",
  "version": "0.1.0",
  "description": "React Native compatible HyperLiquid SDK",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./dist/index.js",
      "browser": "./dist/index.js",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "build:js": "tsc --module ES2020 --outDir dist",
    "build": "rm -rf dist && npm run build:types && npm run build:js"
  },
  "keywords": [
    "hyperliquid",
    "api",
    "sdk",
    "react-native",
    "crypto",
    "trading"
  ],
  "license": "MIT",
  "dependencies": {
    "@msgpack/msgpack": "^3.0.0-beta2",
    "@noble/hashes": "^1.8.0",
    "typescript-event-target": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
