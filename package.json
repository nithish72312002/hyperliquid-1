{
  "name": "hyperliquid-reactnative",
  "version": "0.1.0",
  "description": "React Native compatible HyperLiquid SDK",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./dist/index.js",
      "browser": "./dist/index.js",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsup",
    "prepare": "npm run build"
  },
  "keywords": [
    "hyperliquid",
    "api",
    "sdk",
    "react-native",
    "crypto",
    "trading"
  ],
  "license": "MIT",
  "dependencies": {
    "@msgpack/msgpack": "^3.0.0-beta2",
    "@noble/hashes": "^1.8.0",
    "abortcontroller-polyfill": "^1.7.8",
    "event-target-shim": "^6.0.2",
    "typescript-event-target": "^1.1.1",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
